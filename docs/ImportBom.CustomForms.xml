  <Form ShowImportButton="false" ShowInsertButton="true" ShowEditButton="true" ShowDeleteButton="true" ShowPrintButton="false">
    <Caption>IBom - Mappings</Caption>
    <IconPath></IconPath>
    <RibbonGroup>Tecnologia</RibbonGroup>
    <DatabaseInfo>
      <Table>dbo.Xt_ImportBom_Mappings</Table>
      <Fields>
        <Field ReadOnly="true" InKey="true" InWhere="true" IsProgressive="true">
          <Name>IDMapping</Name>
          <Caption>ID Mapping</Caption>
          <Type>INTEGER</Type>
        </Field>
        <Field InWhere="true" InUpdate="false">
          <Name>Ambito</Name>
          <Caption>Ambito</Caption>
          <Type>VARCHAR(50)</Type>
        </Field>
        <Field InWhere="true" InUpdate="false">
          <Name>CodiceSource</Name>
          <Caption>Codice Source</Caption>
          <Type>VARCHAR(100)</Type>
        </Field>
        <Field InUpdate="true">
          <Name>CodiceTarget</Name>
          <Caption>Codice Target</Caption>
          <Type>VARCHAR(100)</Type>
        </Field>
        <Field InUpdate="true">
          <Name>Descrizione</Name>
          <Caption>Descrizione</Caption>
          <Type>VARCHAR(200)</Type>
        </Field>
      </Fields>
      <Constraints>
        <Unique>Ambito,CodiceSource</Unique>
      </Constraints>
    </DatabaseInfo>
    <FilterInfo>
      <FilterRow>
        <Filter Type="5" MultiSelect="true">
          <Field>Ambito</Field>
          <Caption>Ambito</Caption>
          <Query>SELECT DISTINCT Ambito, Ambito, Ambito FROM dbo.Xt_ImportBom_Mappings ORDER BY Ambito</Query>
        </Filter>
        <Filter Type="2">
          <Field>CodiceSource</Field>
          <Caption>Codice Source</Caption>
        </Filter>
      </FilterRow>
      <FilterRow>
        <Filter Type="2">
          <Field>CodiceTarget</Field>
          <Caption>Codice Target</Caption>
        </Filter>
        <Filter Type="2">
          <Field>Descrizione</Field>
          <Caption>Descrizione</Caption>
        </Filter>
      </FilterRow>
    </FilterInfo>
  </Form>

